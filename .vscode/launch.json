{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Launch NOESIS Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "sourceMaps": false,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
